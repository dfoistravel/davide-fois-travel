---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---
<BaseLayout title="Davide Fois | Consulente di viaggio personale" description="Creo viaggi su misura e ti accompagno dalla prima idea fino al rientro, con assistenza personalizzata.">
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">Viaggi su misura • Assistenza personale</p>
        <h1>Il viaggio che immagini, organizzato con cura.</h1>
        <p class="lead">Ti aiuto a scegliere, progettare e prenotare la vacanza più adatta a te, senza perdere tempo tra centinaia di offerte.</p>
        <div class="actions">
          <a class="button button-primary" href={`${base}preventivo/`}>Richiedi un preventivo gratuito</a>
          <a class="button button-secondary" href="https://davidefois.nuovevacanze.it" target="_blank">Esplora le offerte</a>
        </div>
      </div>
      <div class="hero-card">
        <span class="badge">Consulenza umana, non un semplice motore di ricerca</span>
        <p class="quote">“Parti con un progetto chiaro e un referente che conosce il tuo viaggio.”</p>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Perché scegliere me</p>
        <h2>Più serenità, meno confusione.</h2>
      </div>
      <div class="grid-3">
        <article class="card"><div class="icon">🧭</div><h3>Proposta su misura</h3><p>Parto da budget, periodo, interessi e stile di viaggio per selezionare le alternative più adatte.</p></article>
        <article class="card"><div class="icon">🤝</div><h3>Un referente personale</h3><p>Hai una persona da contattare prima, durante e dopo la partenza.</p></article>
        <article class="card"><div class="icon">⏱️</div><h3>Tempo risparmiato</h3><p>Eviti ore di ricerche e confronti poco chiari: ricevi una proposta ragionata e comprensibile.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">Idee di viaggio</p>
        <h2>Da dove vuoi iniziare?</h2>
      </div>
      <div class="destinations">
        <a class="destination" href={`${base}destinazioni/#giappone`}><small>Asia</small><h3>Giappone</h3></a>
        <a class="destination" href={`${base}destinazioni/#islanda`}><small>Nord Europa</small><h3>Islanda</h3></a>
        <a class="destination" href={`${base}destinazioni/#grecia`}><small>Mediterraneo</small><h3>Grecia</h3></a>
        <a class="destination" href={`${base}destinazioni/#maldive`}><small>Oceano Indiano</small><h3>Maldive</h3></a>
        <a class="destination" href={`${base}destinazioni/#usa`}><small>Nord America</small><h3>Stati Uniti</h3></a>
        <a class="destination" href={`${base}destinazioni/#baltici`}><small>Europa</small><h3>Paesi Baltici</h3></a>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-intro"><p class="eyebrow">Come funziona</p><h2>Tre passaggi semplici.</h2></div>
      <div class="steps">
        <article class="step"><h3>Raccontami il viaggio</h3><p>Compila il modulo con destinazione, periodo, budget e preferenze.</p></article>
        <article class="step"><h3>Ricevi una proposta</h3><p>Valutiamo insieme le soluzioni più coerenti con ciò che cerchi.</p></article>
        <article class="step"><h3>Prenota e parti</h3><p>Confermi la soluzione scelta e ricevi assistenza durante tutto il percorso.</p></article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta">
      <div><p class="eyebrow">Il prossimo viaggio parte da qui</p><h2>Parliamo della tua idea.</h2><p>La richiesta è gratuita e non ti obbliga alla prenotazione.</p></div>
      <a class="button button-primary" href={`${base}preventivo/`}>Inizia ora</a>
    </div>
  </section>
</BaseLayout>
