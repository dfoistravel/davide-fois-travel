---
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts = [
  {slug:'giappone-in-autunno', title:'Giappone in autunno: come organizzare il viaggio', excerpt:'Periodi, tappe e consigli per vivere il foliage giapponese.'},
  {slug:'weekend-a-vilnius', title:'Weekend a Vilnius: itinerario essenziale', excerpt:'Un primo itinerario tra centro storico, quartieri creativi e cucina locale.'}
];
---
<BaseLayout title="Guide di viaggio | Davide Fois Travel Consultant" description="Consigli, itinerari e idee per organizzare il prossimo viaggio.">
  <section class="section"><div class="container">
    <div class="section-intro"><span class="badge">Guide di viaggio</span><h1>Informazioni utili prima di partire.</h1></div>
    <div class="grid-3">
      {posts.map(post => <article class="card"><h2>{post.title}</h2><p>{post.excerpt}</p><a href={`${import.meta.env.BASE_URL}blog/${post.slug}/`}>Leggi la guida →</a></article>)}
    </div>
  </div></section>
</BaseLayout>
