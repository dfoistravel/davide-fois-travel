---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Richiedi un preventivo viaggio | Davide Fois"><section class="page"><div class="container"><div class="section-head"><p class="kicker">Preventivo gratuito</p><h1>Raccontami il viaggio che hai in mente.</h1></div><form class="card form-grid" action="https://formspree.io/f/INSERISCI_ID" method="POST"><label>Nome e cognome<input name="nome" required></label><label>Email<input type="email" name="email" required></label><label>Telefono<input type="tel" name="telefono"></label><label>Destinazione<input name="destinazione" required></label><label>Periodo indicativo<input name="periodo"></label><label>Numero viaggiatori<input type="number" name="viaggiatori" min="1"></label><label>Budget complessivo<input name="budget"></label><label>Tipo di viaggio<select name="tipo"><option>Tour culturale</option><option>Mare e relax</option><option>Crociera</option><option>Viaggio di nozze</option><option>Altro</option></select></label><label class="full">Preferenze<textarea name="messaggio"></textarea></label><div class="full"><button class="button button-dark" type="submit">Invia la richiesta</button></div></form></div></section></BaseLayout>
