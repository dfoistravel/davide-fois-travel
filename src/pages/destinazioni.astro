---
import BaseLayout from '../layouts/BaseLayout.astro';
const destinations = [
  ['giappone','Giappone','Città, cultura, natura e itinerari stagionali, con particolare attenzione alla primavera e al foliage autunnale.'],
  ['islanda','Islanda','Paesaggi vulcanici, cascate, terme e viaggi on the road.'],
  ['grecia','Grecia','Isole, mare, storia e soggiorni adatti a coppie, famiglie e gruppi.'],
  ['maldive','Maldive','Resort, atolli e soluzioni per viaggi romantici o di completo relax.'],
  ['usa','Stati Uniti','City break, parchi nazionali e itinerari coast to coast.'],
  ['baltici','Paesi Baltici','Vilnius, Riga, Tallinn e percorsi culturali ancora poco scontati.']
];
---
<BaseLayout title="Destinazioni e viaggi su misura | Davide Fois" description="Idee e proposte per viaggi in Giappone, Islanda, Grecia, Maldive, Stati Uniti e Paesi Baltici.">
  <section class="section">
    <div class="container">
      <div class="section-intro"><span class="badge">Destinazioni</span><h1>Trova l'ispirazione, poi costruiamo il viaggio.</h1></div>
      <div class="grid-3">
        {destinations.map(([id,name,text]) => (
          <article class="card" id={id}><h2>{name}</h2><p>{text}</p><a href={`${import.meta.env.BASE_URL}preventivo/?destinazione=${encodeURIComponent(name)}`}>Richiedi una proposta →</a></article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
