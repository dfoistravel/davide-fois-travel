---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageCard from '../components/ImageCard.astro';

const base = import.meta.env.BASE_URL;
const tokyoAttractions = [
  {
    image: `${base}images/tokyo/asakusa.webp`,
    alt: 'Tempio Sensō-ji nel quartiere Asakusa a Tokyo',
    title: 'Asakusa e Sensō-ji',
    description:
      'Il quartiere storico più conosciuto di Tokyo. Visita il tempio Sensō-ji, attraversa la porta Kaminarimon e percorri la vivace Nakamise Street.',
  },
  {
    image: `${base}images/tokyo/shibuya.webp`,
    alt: 'Attraversamento pedonale di Shibuya a Tokyo',
    title: 'Shibuya',
    description:
      'Ammira il celebre attraversamento pedonale, la statua di Hachikō e il panorama sulla città dallo Shibuya Sky.',
  },
  {
    image: `${base}images/tokyo/shinjuku.webp`,
    alt: 'Grattacieli illuminati del quartiere Shinjuku a Tokyo',
    title: 'Shinjuku',
    description:
      'Grattacieli, osservatori panoramici, insegne luminose e piccoli locali caratterizzano uno dei quartieri più dinamici di Tokyo.',
  },
  {
    image: `${base}images/tokyo/ueno.webp`,
    alt: 'Parco di Ueno a Tokyo',
    title: 'Ueno',
    description:
      'Un’area ideale per musei, parchi e passeggiate. In primavera il parco di Ueno è uno dei luoghi più frequentati per l’hanami.',
  },
  {
    image: `${base}images/tokyo/harajuku.webp`,
    alt: 'Santuario Meiji e quartiere Harajuku a Tokyo',
    title: 'Harajuku e Meiji Jingu',
    description:
      'Abbina la visita al santuario Meiji, immerso nel verde, con Takeshita Street e le eleganti boutique di Omotesandō.',
  },
  {
    image: `${base}images/tokyo/odaiba.webp`,
    alt: 'Rainbow Bridge e baia di Odaiba a Tokyo',
    title: 'Odaiba',
    description:
      'L’isola artificiale nella baia di Tokyo offre musei interattivi, centri commerciali e splendide viste sul Rainbow Bridge.',
  },
  {
    image: `${base}images/tokyo/tokyo-skytree.webp`,
    alt: 'Tokyo Skytree vista dalla città',
    title: 'Tokyo Skytree',
    description:
      'Una delle torri più alte del mondo, con piattaforme panoramiche dalle quali osservare l’immensa estensione della città.',
  },
  {
    image: `${base}images/tokyo/akihabara.webp`,
    alt: 'Insegne luminose nel quartiere Akihabara a Tokyo',
    title: 'Akihabara',
    description:
      'Il quartiere dedicato a elettronica, manga, anime, videogiochi e cultura pop giapponese.',
  },
  {
    image: `${base}images/tokyo/ginza.webp`,
    alt: 'Boutique e palazzi moderni nel quartiere Ginza a Tokyo',
    title: 'Ginza',
    description:
      'Il quartiere dello shopping elegante, ricco di boutique, grandi magazzini, ristoranti e architetture contemporanee.',
  },
  {
    image: `${base}images/tokyo/toyosu.webp`,
    alt: 'Mercato ittico di Toyosu a Tokyo',
    title: 'Mercato di Toyosu',
    description:
      'Il moderno mercato ittico di Tokyo, ideale per osservare le attività del mercato e provare una colazione a base di sushi.',
  },
  {
    image: `${base}images/tokyo/tokyo-tower.webp`,
    alt: 'Tokyo Tower illuminata durante la sera',
    title: 'Tokyo Tower',
    description:
      'Uno dei simboli della capitale. Salendo sull’osservatorio potrai ammirare un magnifico panorama sulla città, soprattutto al tramonto.',
  },
  {
    image: `${base}images/tokyo/palazzo-imperiale.webp`,
    alt: 'Giardini del Palazzo Imperiale di Tokyo',
    title: 'Palazzo Imperiale',
    description:
      'Residenza dell’Imperatore del Giappone. I giardini orientali sono visitabili gratuitamente e offrono una pausa dal ritmo della metropoli.',
  },
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quanti giorni servono per visitare Tokyo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Per un primo viaggio sono consigliati almeno tre o quattro giorni."
      }
    },
    {
      "@type": "Question",
      "name": "Qual è il periodo migliore per visitare Tokyo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Primavera e autunno sono i periodi migliori grazie al clima piacevole e alla fioritura dei ciliegi o ai colori del foliage."
      }
    },
    {
      "@type": "Question",
      "name": "Meglio Tokyo Skytree o Tokyo Tower?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tokyo Skytree offre il panorama più ampio della città, mentre Tokyo Tower è il simbolo storico della capitale."
      }
    },
    {
      "@type": "Question",
      "name": "Qual è il quartiere più famoso di Tokyo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Shibuya è il quartiere più iconico grazie al celebre attraversamento pedonale, mentre Shinjuku è famoso per i suoi grattacieli e la vita notturna."
      }
    }
  ]
};
---

<BaseLayout
  title="Cosa vedere a Tokyo | Guida completa"
  description="Scopri cosa vedere a Tokyo: quartieri, templi, panorami, mercati, consigli pratici e un itinerario consigliato di 3 giorni."
>
  <section
  class="hero hero--image"
  style={`background-image:
    linear-gradient(
      90deg,
      rgba(8, 31, 59, 0.94) 0%,
      rgba(8, 31, 59, 0.76) 48%,
      rgba(8, 31, 59, 0.28) 100%
    ),
    url('${base}images/tokyo/hero-tokyo.webp');`}
>
  <div class="container">
    <div class="hero__content">
      <p class="kicker">Guida Tokyo</p>

      <h1>Cosa vedere a Tokyo: guida completa per il primo viaggio</h1>

      <p class="lead">
        Dai templi di Asakusa ai grattacieli di Shinjuku, passando per
        Shibuya, Harajuku e Odaiba: scopri le attrazioni e le esperienze
        imperdibili della capitale giapponese.
      </p>

      <a
        class="button button-primary"
        href={`${base}preventivo/?destinazione=Giappone`}
      >
        Richiedi un preventivo gratuito
      </a>
    </div>
  </div>
</section>

  <section class="section">
    <div class="container">
      <h2>Tokyo: tradizione e futuro nella stessa città</h2>

      <p>
        Tokyo è una metropoli immensa, composta da quartieri molto diversi
        tra loro. In una sola giornata puoi visitare un antico santuario,
        passeggiare tra boutique e locali alla moda e osservare la città
        dall’alto di un grattacielo.
      </p>

      <p>
        Per un primo viaggio consiglio di dedicare almeno tre o quattro
        giorni alla capitale, organizzando le visite per zone vicine e
        limitando gli spostamenti inutili.
      </p>
    </div>
  </section>
<section class="section">
  <div class="container">
    <div class="section-heading section-heading--center">
      <p class="kicker">Orientarsi a Tokyo</p>
      <h2>Le attrazioni di Tokyo sulla mappa</h2>
      <p>
        Visualizza le zone principali della capitale e organizza le visite
        raggruppando i quartieri più vicini.
      </p>
    </div>

    <div class="tokyo-map-layout">
      <div class="tokyo-map">
        <iframe
          title="Mappa delle principali attrazioni di Tokyo"
          src="https://www.google.com/maps?q=Tokyo%20Japan&z=11&output=embed"
          width="100%"
          height="560"
          style="border:0;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        >
        </iframe>
      </div>

      <div class="tokyo-map-list">
        <h3>Zone e attrazioni principali</h3>

        <ol>
          <li><strong>Asakusa e Sensō-ji</strong><span>Tokyo tradizionale</span></li>
          <li><strong>Shibuya</strong><span>Incrocio e vita urbana</span></li>
          <li><strong>Shinjuku</strong><span>Grattacieli e panorami</span></li>
          <li><strong>Ueno</strong><span>Parco e musei</span></li>
          <li><strong>Harajuku e Meiji Jingu</strong><span>Moda e spiritualità</span></li>
          <li><strong>Odaiba</strong><span>Baia e architettura moderna</span></li>
          <li><strong>Tokyo Skytree</strong><span>Vista panoramica</span></li>
          <li><strong>Akihabara</strong><span>Anime, manga ed elettronica</span></li>
          <li><strong>Ginza</strong><span>Shopping e ristoranti</span></li>
          <li><strong>Mercato di Toyosu</strong><span>Mercato ittico e sushi</span></li>
          <li><strong>Tokyo Tower</strong><span>Simbolo della capitale</span></li>
          <li><strong>Palazzo Imperiale</strong><span>Giardini e storia</span></li>
        </ol>
      </div>
    </div>
  </div>
</section>
  <section class="section alt">
    <div class="container">
      <h2>Le attrazioni imperdibili di Tokyo</h2>

      <div class="grid-3">
      {
  tokyoAttractions.map((attraction) => (
    <ImageCard
      image={attraction.image}
      alt={attraction.alt}
      title={attraction.title}
      description={attraction.description}
    />
  ))
}
        
       </div>
    </div>
  </section>
  <section class="section alt">
  <div class="container">
    <div class="section-heading section-heading--center">
      <p class="kicker">Itinerario consigliato</p>

      <h2>Come organizzare le visite a Tokyo</h2>

      <p>
        Per ridurre gli spostamenti conviene visitare nella stessa giornata
        i quartieri più vicini. Questa suddivisione è ideale per un primo
        viaggio di tre giorni nella capitale giapponese.
      </p>
    </div>

    <div class="grid-3">
      <article class="card">
        <h3>Giorno 1: Tokyo tradizionale</h3>

        <ul>
          <li>Asakusa e Sensō-ji</li>
          <li>Ueno</li>
          <li>Tokyo Skytree</li>
        </ul>

        <p>
          Una giornata dedicata ai quartieri storici, ai templi e ai
          panorami della zona orientale di Tokyo.
        </p>
      </article>

      <article class="card">
        <h3>Giorno 2: quartieri iconici</h3>

        <ul>
          <li>Meiji Jingu e Harajuku</li>
          <li>Shibuya</li>
          <li>Shinjuku</li>
        </ul>

        <p>
          Un itinerario tra santuari, moda, attraversamenti celebri,
          grattacieli e vita serale.
        </p>
      </article>

      <article class="card">
        <h3>Giorno 3: baia e centro</h3>

        <ul>
          <li>Mercato di Toyosu</li>
          <li>Ginza</li>
          <li>Palazzo Imperiale</li>
          <li>Tokyo Tower</li>
        </ul>

        <p>
          Una giornata tra mercato, shopping, storia imperiale e uno dei
          panorami più famosi della capitale.
        </p>
      </article>
    </div>
  </div>
</section>
  
  <section class="section alt">
    <div class="container">
      <h2>Consigli pratici per visitare Tokyo</h2>

      <ul>
        <li>
          Organizza le giornate raggruppando quartieri vicini tra loro.
        </li>
        <li>
          Utilizza una carta IC ricaricabile per metropolitana, treni e
          piccoli acquisti.
        </li>
        <li>
          Evita, quando possibile, le ore di punta dei mezzi pubblici.
        </li>
        <li>
          Prenota in anticipo gli osservatori e le attrazioni più richieste.
        </li>
        <li>
          Indossa scarpe comode: durante una giornata a Tokyo si cammina molto.
        </li>
        <li>
          Controlla l’ultima corsa della metropolitana prima di trascorrere
          la serata lontano dal tuo hotel.
        </li>
      </ul>
    </div>
  </section>
<section class="section">
  <div class="container">

    <div class="section-heading section-heading--center">
      <p class="kicker">Domande frequenti</p>

      <h2>FAQ su Tokyo</h2>

      <p>
        Le risposte alle domande più frequenti per organizzare un primo viaggio a Tokyo.
      </p>
    </div>

    <div class="grid-2">

      <article class="card">
        <h3>Quanti giorni servono per visitare Tokyo?</h3>

        <p>
          Per un primo viaggio sono consigliati almeno tre o quattro giorni.
          Questo permette di visitare i quartieri principali senza fretta.
        </p>
      </article>

      <article class="card">
        <h3>Qual è il periodo migliore per visitare Tokyo?</h3>

        <p>
          Primavera e autunno sono i periodi migliori grazie al clima piacevole,
          ai ciliegi in fiore e ai colori del foliage.
        </p>
      </article>

      <article class="card">
        <h3>Meglio Tokyo Skytree o Tokyo Tower?</h3>

        <p>
          Tokyo Skytree offre il panorama più ampio della città,
          mentre Tokyo Tower è il simbolo storico della capitale.
        </p>
      </article>

      <article class="card">
        <h3>Qual è il quartiere più famoso di Tokyo?</h3>

        <p>
          Shibuya è il quartiere più iconico grazie al celebre attraversamento
          pedonale, mentre Shinjuku è famoso per i suoi grattacieli e la vita
          notturna.
        </p>
      </article>

    </div>

  </div>
</section>
  <section class="section">
    <div class="container">
      <h2>Quando visitare Tokyo</h2>

      <p>
  Approfondisci la scelta del periodo nella guida{' '}
  <a href={`${base}quando-andare-giappone/`}>
    Quando andare in Giappone
  </a>.
</p>

        </div>
  </section>

  <section class="section alt">
    <div class="container">
      <h2>Inserire Tokyo in un itinerario in Giappone</h2>

      <p>
        Tokyo può essere il punto di partenza di un viaggio che prosegue verso
        Hakone, il Monte Fuji, Kyoto, Nara, Osaka e Hiroshima.
      </p>

      <p>
  Consulta anche{' '}
  <a href={`${base}itinerario-giappone-10-giorni/`}>
    l’itinerario in Giappone di 10 giorni
  </a>{' '}
  oppure{' '}
  <a href={`${base}itinerario-giappone-14-giorni/`}>
    l’itinerario in Giappone di 14 giorni
  </a>.
</p>
    </div>
  </section>

  <section class="section">
    <div class="container cta">
      <h2>Vuoi un itinerario su misura?</h2>

      <p>
        Posso aiutarti a scegliere quartieri, hotel, esperienze e tappe in
        base al periodo del viaggio, alle tue preferenze e al tuo budget.
      </p>

      <a
        class="button button-primary"
        href={`${base}preventivo/?destinazione=Giappone`}
      >
        Richiedi il preventivo gratuito
      </a>
    </div>
  </section>
</BaseLayout>
