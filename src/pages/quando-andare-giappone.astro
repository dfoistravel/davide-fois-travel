---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const months = [
  ["Gennaio","❄️ Freddo","⭐","€€","Neve, onsen, Hokkaido"],
  ["Febbraio","❄️ Freddo","⭐","€€","Snow Festival, sci"],
  ["Marzo","🌸 Mite","⭐⭐⭐","€€€","Primi ciliegi e hanami"],
  ["Aprile","🌸 Mite","⭐⭐⭐⭐⭐","€€€€","Ciliegi in fiore"],
  ["Maggio","☀️ Piacevole","⭐⭐⭐","€€€","Città, natura e trekking"],
  ["Giugno","🌦 Piovoso","⭐","€","Budget e città meno affollate"],
  ["Luglio","☀️ Caldo","⭐⭐","€€","Festival e montagne"],
  ["Agosto","☀️ Molto caldo","⭐⭐⭐","€€€","Hokkaido, mare e matsuri"],
  ["Settembre","🍃 Variabile","⭐⭐","€€","Meno folla e fine estate"],
  ["Ottobre","🍁 Piacevole","⭐⭐⭐","€€","Prime zone di foliage"],
  ["Novembre","🍁 Fresco","⭐⭐","€€","Momiji e foliage"],
  ["Dicembre","❄️ Freddo","⭐","€€","Illuminazioni e primi paesaggi innevati"]
];

const faq = [
  ["Qual è il mese migliore per andare in Giappone?","Aprile, maggio, ottobre e novembre sono generalmente tra i mesi più apprezzati. La scelta migliore dipende però dalle regioni visitate, dal budget e dal tipo di esperienza desiderata."],
  ["Quando vedere i ciliegi in fiore?","Nelle principali città del Giappone centrale la fioritura avviene spesso tra fine marzo e inizio aprile, ma le date cambiano ogni anno."],
  ["Quando vedere il foliage in Giappone?","Il foliage inizia nelle regioni settentrionali e montane e raggiunge più tardi città come Kyoto e Tokyo. Novembre è spesso uno dei mesi più indicati."],
  ["Qual è il periodo meno costoso?","Alcune settimane di gennaio, febbraio, giugno e settembre possono offrire prezzi più convenienti, evitando festività ed eventi importanti."],
  ["Quali sono i periodi più affollati?","Hanami, Golden Week, Obon, Capodanno e foliage nelle località più famose sono tra i periodi con maggiore affluenza."],
  ["Meglio primavera o autunno?","La primavera è ideale per i ciliegi; l'autunno offre temperature piacevoli, foliage e spesso condizioni più stabili."],
  ["Si può visitare il Giappone in estate?","Sì, ma occorre prepararsi a caldo e umidità. Hokkaido e le zone montane sono spesso più confortevoli."],
  ["Quanti giorni servono per un primo viaggio?","Per un primo itinerario completo sono consigliabili almeno 10-14 giorni."]
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Quando andare in Giappone: clima, stagioni e periodo migliore",
      "description": "Guida completa per scegliere il periodo migliore per visitare il Giappone.",
      "author": { "@type": "Person", "name": "Davide Fois" },
      "publisher": { "@type": "Organization", "name": "Davide Fois Travel Consultant" },
      "mainEntityOfPage": new URL(`${base}quando-andare-giappone/`, Astro.site).href,
      "inLanguage": "it-IT"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faq.map(([question, answer]) => ({
        "@type": "Question",
        "name": question,
        "acceptedAnswer": { "@type": "Answer", "text": answer }
      }))
    }
  ]
};
---

<BaseLayout
  title="Quando andare in Giappone | Clima, stagioni e periodo migliore"
  description="Scopri quando andare in Giappone: clima mese per mese, ciliegi, foliage, periodi meno affollati e consigli per scegliere la stagione migliore."
  schema={schema}
>
  <section class="hero japan-hero">
    <div class="container hero-grid">
      <div>
        <p class="kicker">Guida Giappone 2026</p>
        <h1>Quando andare in Giappone: scegli il periodo giusto per il tuo viaggio.</h1>
        <p class="lead">
          Sakura, foliage, festival, neve e onsen: ogni stagione offre un Giappone diverso.
          Questa guida ti aiuta a scegliere il periodo più adatto in base a clima, budget,
          affollamento ed esperienza.
        </p>
        <div class="actions">
          <a class="button button-primary" href={`${base}preventivo/?destinazione=Giappone`}>
            Richiedi un preventivo gratuito
          </a>
          <a class="button button-ghost" href="#calendario">Guarda il calendario</a>
        </div>
      </div>

      <div class="executive-visual" aria-hidden="true">
        <div class="executive-orbit"></div>
        <div class="executive-plane">✈</div>
        <div class="executive-card">
          <span class="badge">Periodo consigliato</span>
          <strong>Primavera e autunno sono i grandi classici.</strong>
          <p>Ma inverno ed estate possono offrire esperienze più autentiche e meno affollate.</p>
        </div>
      </div>
    </div>
  </section>

  <nav class="container breadcrumb" aria-label="Breadcrumb">
    <a href={base}>Home</a><span>›</span>
    <a href={`${base}giappone/`}>Giappone</a><span>›</span>
    <span>Quando andare</span>
  </nav>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="kicker">La risposta in breve</p>
        <h2>Qual è il periodo migliore per visitare il Giappone?</h2>
        <p>Non esiste una risposta valida per tutti: dipende dalle regioni, dal budget e dalle esperienze desiderate.</p>
      </div>
      <div class="grid-3">
        <article class="card"><div class="icon">🌸</div><h3>Primavera</h3><p>Hanami, ciliegi, giardini e temperature miti.</p></article>
        <article class="card"><div class="icon">☀️</div><h3>Estate</h3><p>Festival, montagne, Hokkaido e atmosfera locale.</p></article>
        <article class="card"><div class="icon">🍁</div><h3>Autunno</h3><p>Foliage, clima piacevole e natura.</p></article>
        <article class="card"><div class="icon">❄️</div><h3>Inverno</h3><p>Neve, onsen, sci e meno visitatori.</p></article>
      </div>
    </div>
  </section>

  <section class="section" id="calendario">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Guida mese per mese</p>
        <h2>Quando andare in Giappone durante l'anno.</h2>
      </div>
      <div class="table-wrapper">
        <table class="travel-table">
          <thead><tr><th>Mese</th><th>Clima</th><th>Affluenza</th><th>Prezzi</th><th>Ideale per</th></tr></thead>
          <tbody>
            {months.map(([mese, clima, affluenza, prezzi, ideale]) => (
              <tr><td><strong>{mese}</strong></td><td>{clima}</td><td>{affluenza}</td><td>{prezzi}</td><td>{ideale}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Il riepilogo</p>
        <h2>Qual è il periodo migliore per il tuo viaggio?</h2>
      </div>
      <div class="grid-3">
        <article class="card"><h3>🌸 Hanami</h3><p>Fine marzo – inizio aprile, soprattutto tra Tokyo, Kyoto e Nara.</p></article>
        <article class="card"><h3>🍁 Foliage</h3><p>Ottobre e novembre, dalle Alpi Giapponesi a Kyoto.</p></article>
        <article class="card"><h3>💰 Budget</h3><p>Gennaio, febbraio, giugno e settembre possono essere più convenienti.</p></article>
        <article class="card"><h3>♨️ Onsen e neve</h3><p>Gennaio e febbraio per Hokkaido, Nagano e località termali.</p></article>
        <article class="card"><h3>☀️ Clima ideale</h3><p>Aprile, maggio e novembre sono generalmente molto equilibrati.</p></article>
        <article class="card"><h3>👨‍💼 Il mio consiglio</h3><p>Per un primo viaggio valuta ottobre o novembre.</p></article>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Dove andare</p>
        <h2>Dove andare in Giappone in ogni stagione.</h2>
      </div>
      <div class="season-destination-grid">
        <article class="season-destination-card"><div class="season-symbol">🌸</div><div><h3>Primavera</h3><p class="season-destination-places">Tokyo • Kyoto • Nara • Osaka</p><p>Hanami, giardini e templi.</p></div></article>
        <article class="season-destination-card"><div class="season-symbol">☀️</div><div><h3>Estate</h3><p class="season-destination-places">Hokkaido • Alpi Giapponesi • Tohoku</p><p>Trekking, natura e festival.</p></div></article>
        <article class="season-destination-card"><div class="season-symbol">🍁</div><div><h3>Autunno</h3><p class="season-destination-places">Kyoto • Nikko • Takayama • Hakone</p><p>Foliage e fotografia.</p></div></article>
        <article class="season-destination-card"><div class="season-symbol">❄️</div><div><h3>Inverno</h3><p class="season-destination-places">Hokkaido • Nagano • Shirakawa-go</p><p>Neve, sci e onsen.</p></div></article>
      </div>
      <div class="season-message">
        <strong>Non esiste un periodo perfetto per tutti.</strong>
        <p>Esiste il periodo più adatto al viaggio che desideri vivere.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Il Giappone sulla mappa</p>
        <h2>Regioni ed esperienze da scegliere in base alla stagione.</h2>
      </div>

      <div class="japan-map-layout">
        <div class="japan-map" aria-label="Mappa stilizzata del Giappone">
          <div class="map-line"></div>
          <article class="map-point map-point-1"><span class="map-dot"></span><div><small>Nord</small><h3>Hokkaido</h3><p>Estate e inverno</p></div></article>
          <article class="map-point map-point-2"><span class="map-dot"></span><div><small>Nord-est</small><h3>Tohoku</h3><p>Primavera e autunno</p></div></article>
          <article class="map-point map-point-3"><span class="map-dot"></span><div><small>Centro-est</small><h3>Tokyo e Nikko</h3><p>Primavera e autunno</p></div></article>
          <article class="map-point map-point-4"><span class="map-dot"></span><div><small>Centro</small><h3>Alpi Giapponesi</h3><p>Estate, autunno e inverno</p></div></article>
          <article class="map-point map-point-5"><span class="map-dot"></span><div><small>Kansai</small><h3>Kyoto, Osaka e Nara</h3><p>Primavera e autunno</p></div></article>
          <article class="map-point map-point-6"><span class="map-dot"></span><div><small>Sud-ovest</small><h3>Hiroshima e Miyajima</h3><p>Primavera e autunno</p></div></article>
          <article class="map-point map-point-7"><span class="map-dot"></span><div><small>Estremo sud</small><h3>Okinawa</h3><p>Primavera ed estate</p></div></article>
        </div>

        <div class="region-guide">
          <article class="region-card"><span>❄️</span><div><h3>Hokkaido</h3><p>Estate fresca, neve, sci e festival invernali.</p></div></article>
          <article class="region-card"><span>🌸</span><div><h3>Tokyo e Kyoto</h3><p>Ciliegi, templi, giardini e hanami.</p></div></article>
          <article class="region-card"><span>🍁</span><div><h3>Nikko e Alpi Giapponesi</h3><p>Foliage, montagne e fotografia.</p></div></article>
          <article class="region-card"><span>🌊</span><div><h3>Okinawa</h3><p>Mare tropicale e ritmo più rilassato.</p></div></article>
          <div class="region-note"><strong>Consiglio di pianificazione</strong><p>Un itinerario può seguire le stagioni da nord a sud o combinare climi differenti.</p></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head"><p class="kicker">Domande frequenti</p><h2>Le risposte per scegliere con maggiore sicurezza.</h2></div>
      <div class="faq-grid">
        {faq.map(([question, answer]) => (
          <details class="faq-item"><summary>{question}</summary><p>{answer}</p></details>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta executive-cta">
      <div>
        <p class="kicker">Progettiamo il periodo giusto</p>
        <h2>Raccontami il Giappone che vuoi vivere.</h2>
        <p>Ti aiuterò a scegliere date, tappe e durata in base al budget e alle stagioni.</p>
      </div>
      <a class="button button-primary" href={`${base}preventivo/?destinazione=Giappone`}>
        Richiedi il preventivo gratuito
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .breadcrumb{display:flex;gap:10px;align-items:center;padding-top:22px;font-size:.92rem;color:var(--muted)}
  .breadcrumb a{font-weight:700;text-decoration:none}
  .table-wrapper{overflow-x:auto;margin-top:2rem;border-radius:22px;box-shadow:0 18px 45px rgba(11,31,58,.08)}
  .travel-table{width:100%;min-width:760px;border-collapse:collapse;background:#fff}
  .travel-table th{background:#102544;color:#fff;padding:18px;text-align:left}
  .travel-table td{padding:18px;border-bottom:1px solid #ececec}
  .travel-table tr:hover{background:#faf6ea}
  .season-destination-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
  .season-destination-card{display:grid;grid-template-columns:auto 1fr;gap:20px;padding:28px;border:1px solid var(--line);border-radius:24px;background:#fff;box-shadow:0 12px 34px rgba(11,31,58,.06)}
  .season-symbol{display:flex;align-items:center;justify-content:center;width:54px;height:54px;border-radius:16px;background:#f7f0d5;font-size:1.6rem}
  .season-destination-places{font-weight:800;color:var(--navy)}
  .season-message{margin-top:28px;padding:28px 30px;border-left:5px solid var(--gold);border-radius:18px;background:#fff8e8}
  .japan-map-layout{display:grid;grid-template-columns:1fr 1fr;gap:34px}
  .japan-map{position:relative;min-height:720px;padding:38px 30px;border-radius:30px;background:linear-gradient(145deg,#0b1f3a,#173c62);box-shadow:0 24px 60px rgba(11,31,58,.18);overflow:hidden}
  .map-line{position:absolute;top:54px;bottom:54px;left:50%;width:5px;border-radius:999px;background:linear-gradient(to bottom,#f1cf54,#fff,#f1cf54);transform:translateX(-50%) rotate(12deg);opacity:.75}
  .map-point{position:absolute;display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:center;width:220px;color:#fff}
  .map-point small{color:#f1cf54;font-size:.76rem;font-weight:800;text-transform:uppercase}
  .map-point h3{margin:0;color:#fff;font-size:1.08rem}
  .map-point p{margin:0;color:#dbe6f2;font-size:.88rem}
  .map-dot{width:18px;height:18px;border:4px solid #fff;border-radius:50%;background:#f1cf54;box-shadow:0 0 0 6px rgba(241,207,84,.18)}
  .map-point-1{top:7%;right:7%}.map-point-2{top:20%;left:6%}.map-point-3{top:34%;right:3%}.map-point-4{top:48%;left:5%}.map-point-5{top:61%;right:4%}.map-point-6{top:75%;left:4%}.map-point-7{bottom:4%;right:6%}
  .region-guide{display:grid;gap:18px}
  .region-card{display:grid;grid-template-columns:auto 1fr;gap:18px;padding:24px;border:1px solid var(--line);border-radius:22px;background:#fff;box-shadow:0 12px 34px rgba(11,31,58,.06)}
  .region-card>span{display:flex;align-items:center;justify-content:center;width:54px;height:54px;border-radius:16px;background:#f7f0d5;font-size:1.5rem}
  .region-note{padding:28px;border-left:5px solid var(--gold);border-radius:20px;background:#fff8e8}
  @media(max-width:900px){.season-destination-grid,.japan-map-layout{grid-template-columns:1fr}}
  @media(max-width:620px){
    .season-destination-grid{grid-template-columns:1fr}
    .japan-map{min-height:auto;padding:24px}
    .map-line{display:none}
    .map-point{position:relative;top:auto;right:auto;bottom:auto;left:auto;width:100%;margin-bottom:24px}
  }
</style>
