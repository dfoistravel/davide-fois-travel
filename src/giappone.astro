---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const faq = [
  {
    question: "Qual è il periodo migliore per visitare il Giappone?",
    answer:
      "Dipende dal tipo di esperienza desiderata. La primavera è ideale per i ciliegi, l’autunno per il foliage, l’inverno per neve e onsen, mentre l’estate offre festival e zone montane."
  },
  {
    question: "Quanti giorni servono per un primo viaggio?",
    answer:
      "Per un primo viaggio consiglio almeno 10-14 giorni, così da visitare Tokyo, Kyoto, Osaka e inserire una o due escursioni."
  },
  {
    question: "È possibile creare un itinerario personalizzato?",
    answer:
      "Sì. Periodo, budget, interessi e ritmo di viaggio vengono utilizzati per costruire una proposta su misura."
  },
  {
    question: "Quanto costa un viaggio in Giappone?",
    answer:
      "Il costo dipende da voli, durata, categoria degli hotel, spostamenti e periodo. Un preventivo personalizzato permette di stimare il budget in modo più preciso."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TouristDestination",
      "name": "Giappone",
      "description":
        "Guida alla progettazione di un viaggio personalizzato in Giappone."
    },
    {
      "@type": "FAQPage",
      "mainEntity": faq.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    }
  ]
};
---

<BaseLayout
  title="Viaggio in Giappone | Itinerari su misura con Davide Fois"
  description="Organizza un viaggio in Giappone con un itinerario personalizzato. Scopri città, stagioni, trasporti e consigli pratici con assistenza dedicata."
  schema={schema}
>
  <section class="hero japan-hero">
    <div class="container hero-grid">
      <div>
        <p class="kicker">Giappone Premium</p>

        <h1>Scopri il Giappone con un viaggio costruito intorno a te.</h1>

        <p class="lead">
          Dalle metropoli ultramoderne ai templi immersi nel silenzio,
          creo itinerari personalizzati in base ai tuoi interessi,
          al periodo dell’anno e al budget disponibile.
        </p>

        <div class="actions">
          <a class="button button-primary" href={`${base}preventivo/`}>
            Richiedi un preventivo gratuito
          </a>

          <a class="button button-ghost" href="#itinerari">
            Scopri gli itinerari
          </a>
        </div>
      </div>

      <div class="executive-visual" aria-hidden="true">
        <div class="executive-orbit"></div>
        <div class="executive-plane">✈</div>
        <div class="executive-card">
          <span class="badge">Viaggio su misura</span>
          <strong>Tradizione, natura e innovazione.</strong>
          <p>
            Un itinerario pensato per il tuo modo di viaggiare,
            non un pacchetto standard.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Perché scegliere il Giappone</p>
        <h2>Un Paese capace di cambiare volto in ogni stagione.</h2>
      </div>

      <div class="grid-3">
        <article class="card">
          <div class="icon">🏯</div>
          <h3>Cultura e tradizione</h3>
          <p>
            Templi, castelli, giardini e quartieri storici raccontano
            una storia millenaria.
          </p>
        </article>

        <article class="card">
          <div class="icon">🍁</div>
          <h3>Natura e stagioni</h3>
          <p>
            Sakura, foliage, montagne, laghi, onsen e paesaggi diversi
            durante tutto l’anno.
          </p>
        </article>

        <article class="card">
          <div class="icon">🚄</div>
          <h3>Innovazione e comodità</h3>
          <p>
            Trasporti efficienti, città futuristiche e servizi pensati
            per rendere il viaggio più semplice.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Quando andare</p>
        <h2>Ogni stagione offre un’esperienza diversa.</h2>
      </div>

      <div class="grid-3">
        <article class="card">
          <h3>Primavera</h3>
          <p>
            Ciliegi in fiore, clima mite e giardini ideali per l’hanami.
          </p>
        </article>

        <article class="card">
          <h3>Estate</h3>
          <p>
            Festival, fuochi d’artificio, montagne e isole del sud.
          </p>
        </article>

        <article class="card">
          <h3>Autunno</h3>
          <p>
            Foliage spettacolare, temperature piacevoli e colori intensi.
          </p>
        </article>

        <article class="card">
          <h3>Inverno</h3>
          <p>
            Neve, onsen, sci e paesaggi alpini in Hokkaido e nelle Alpi.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Destinazioni principali</p>
        <h2>Le tappe più amate per un primo viaggio.</h2>
      </div>

      <div class="grid-3">
        <article class="card">
          <h3>Tokyo</h3>
          <p>Quartieri futuristici, templi, musei e vita urbana.</p>
        </article>

        <article class="card">
          <h3>Kyoto</h3>
          <p>Templi, giardini zen, Gion e tradizioni secolari.</p>
        </article>

        <article class="card">
          <h3>Osaka</h3>
          <p>Atmosfera vivace, street food e cultura gastronomica.</p>
        </article>

        <article class="card">
          <h3>Nara</h3>
          <p>Il Grande Buddha e i celebri cervi del parco.</p>
        </article>

        <article class="card">
          <h3>Monte Fuji e Hakone</h3>
          <p>Laghi, funivie, onsen e panorami iconici.</p>
        </article>

        <article class="card">
          <h3>Hiroshima e Miyajima</h3>
          <p>Storia, memoria e uno dei torii più famosi del Giappone.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="itinerari">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Itinerari suggeriti</p>
        <h2>Scegli la durata più adatta al tuo viaggio.</h2>
      </div>

      <div class="grid-3">
        <article class="card">
          <h3>7 giorni</h3>
          <p>Tokyo e Kyoto, con ritmi intensi e tappe essenziali.</p>
        </article>

        <article class="card">
          <h3>10 giorni</h3>
          <p>Tokyo, Kyoto, Osaka e una prima escursione.</p>
        </article>

        <article class="card">
          <h3>14 giorni</h3>
          <p>
            Tokyo, Kyoto, Osaka, Nara, Hiroshima, Miyajima e Hakone.
          </p>
        </article>

        <article class="card">
          <h3>21 giorni</h3>
          <p>
            Un viaggio completo con regioni meno conosciute e ritmi più rilassati.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section class="section alt">
    <div class="container">
      <div class="section-head">
        <p class="kicker">Domande frequenti</p>
        <h2>Le risposte prima di iniziare.</h2>
      </div>

      <div class="faq-grid">
        {faq.map(item => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta executive-cta">
      <div>
        <p class="kicker">Il tuo viaggio inizia qui</p>
        <h2>Raccontami il Giappone che immagini.</h2>
        <p>
          Ti aiuterò a trasformare la tua idea in un itinerario organizzato
          sulle tue esigenze.
        </p>
      </div>

      <a class="button button-primary" href={`${base}preventivo/`}>
        Richiedi il preventivo gratuito
      </a>
    </div>
  </section>
</BaseLayout>
