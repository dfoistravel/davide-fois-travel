---
import '../styles/global.css';
const { title='Davide Fois Travel Consultant', description='Viaggi su misura con assistenza personale prima, durante e dopo la partenza.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="it">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width">
<meta name="description" content={description}><meta name="theme-color" content="#0b1f3a">
<link rel="canonical" href={canonical}><link rel="icon" href={`${base}favicon.svg`}>
<meta property="og:type" content="website"><meta property="og:title" content={title}>
<meta property="og:description" content={description}><meta property="og:url" content={canonical}>
<meta property="og:image" content={new URL(`${base}og-image.svg`, Astro.site)}>
<title>{title}</title>
</head>
<body>
<header class="site-header"><div class="container nav">
<a class="brand" href={base}><span class="brand-mark">DF</span><span class="brand-copy">Davide Fois <small>Travel Consultant • Powered by Nuovevacanze</small></span></a>
<nav class="nav-links"><a href={`${base}chi-sono/`}>Chi sono</a><a href={`${base}destinazioni/`}>Destinazioni</a><a href={`${base}blog/`}>Guide</a><a class="button button-dark" href={`${base}preventivo/`}>Richiedi preventivo</a></nav>
</div></header>
<main><slot /></main>
<a class="whatsapp" aria-label="Contattami su WhatsApp" href="https://wa.me/393389028812" target="_blank">◉</a>
<footer class="site-footer"><div class="container footer-grid">
<div><strong>Davide Fois Travel Consultant</strong><p>Consulenza personalizzata e accesso alle proposte Nuovevacanze.</p></div>
<div><strong>Esplora</strong><br><a href={`${base}destinazioni/`}>Destinazioni</a><br><a href={`${base}blog/`}>Guide</a><br><a href={`${base}preventivo/`}>Preventivo</a></div>
<div><strong>Informazioni</strong><br><a href={`${base}privacy/`}>Privacy</a><br><a href="https://davidefois.nuovevacanze.it" target="_blank">Catalogo Nuovevacanze</a></div>
</div></footer>
</body></html>
