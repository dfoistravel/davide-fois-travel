---
interface Props {
  image: string;
  alt: string;
  title: string;
  description: string;
  href?: string;
  linkLabel?: string;
}

const {
  image,
  alt,
  title,
  description,
  href,
  linkLabel = 'Scopri di più',
} = Astro.props;
---

<article class="image-card">
  <img
    class="image-card__image"
    src={image}
    alt={alt}
    loading="lazy"
    width="800"
    height="600"
  />

  <div class="image-card__content">
    <h3>{title}</h3>

    <p>{description}</p>

    {
      href && (
        <a class="image-card__link" href={href}>
          {linkLabel} →
        </a>
      )
    }
  </div>
</article>
