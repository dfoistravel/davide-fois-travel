---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const faq = [
  { question: "Quanto costa richiedere un preventivo?", answer: "La richiesta iniziale è gratuita e non comporta alcun obbligo di prenotazione." },
  { question: "Posso ricevere un itinerario completamente personalizzato?", answer: "Sì. Periodo, budget, interessi e stile di viaggio vengono usati per costruire una proposta su misura." },
  { question: "Riceverò assistenza anche dopo la prenotazione?", answer: "Sì. Resto il tuo punto di riferimento prima, durante e dopo il viaggio." },
  { question: "Posso chiedere un viaggio in Giappone?", answer: "Sì. Il Giappone è una delle destinazioni principali, con itinerari dedicati a città, cultura, natura, hanami e foliage." }
];
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebSite", "name": "Davide Fois Travel Consultant", "url": new URL(base, Astro.site).href, "inLanguage": "it-IT" },
    { "@type": "TravelAgency", "name": "Davide Fois Travel Consultant", "url": new URL(base, Astro.site).href, "description": "Consulenza per viaggi personalizzati in Giappone, Lituania e nel mondo.", "areaServed": "IT", "sameAs": ["https://davidefois.nuovevacanze.it"] },
    { "@type": "Person", "name": "Davide Fois", "jobTitle": "Travel Consultant", "worksFor": { "@type": "Organization", "name": "Nuovevacanze" } },
    { "@type": "FAQPage", "mainEntity": faq.map(item => ({ "@type": "Question", "name": item.question, "acceptedAnswer": { "@type": "Answer", "text": item.answer } })) }
  ]
};
---
<BaseLayout title="Davide Fois Travel Consultant | Viaggi su misura in Giappone e nel mondo" description="Organizza il tuo viaggio su misura con Davide Fois Travel Consultant. Itinerari personalizzati in Giappone, Lituania e nel mondo con assistenza completa." schema={schema}>
<section class="hero executive-hero"><div class="container hero-grid"><div class="hero-copy"><p class="kicker">Travel Consultant • Powered by Nuovevacanze</p><h1>Viaggi su misura creati intorno ai tuoi desideri.</h1><p class="lead">Progetto itinerari personalizzati in Giappone, Lituania e nelle destinazioni più affascinanti del mondo, accompagnandoti dalla pianificazione fino al rientro.</p><div class="actions"><a class="button button-primary" href={`${base}preventivo/`}>Richiedi il tuo preventivo gratuito</a><a class="button button-ghost" href={`${base}destinazioni/`}>Scopri le destinazioni</a></div><div class="trust-row"><span>✓ Preventivo senza impegno</span><span>✓ Assistenza personale</span><span>✓ Supporto prima, durante e dopo</span></div></div><div class="executive-visual" aria-hidden="true"><div class="executive-orbit"></div><div class="executive-plane">✈</div><div class="executive-card"><span class="badge">Consulenza personale</span><strong>Un solo referente per tutto il viaggio.</strong><p>Più chiarezza, meno tempo perso e una proposta costruita davvero intorno a te.</p></div></div></div></section>
<section class="section executive-strip"><div class="container stats-grid"><article><strong>1</strong><span>referente personale</span></article><article><strong>100%</strong><span>proposte personalizzate</span></article><article><strong>3</strong><span>fasi: ascolto, proposta, partenza</span></article><article><strong>24/7</strong><span>accesso al sito e alle richieste</span></article></div></section>
<section class="section alt"><div class="container"><div class="section-head"><p class="kicker">Perché scegliere Davide</p><h2>Un servizio umano, chiaro e costruito intorno a te.</h2><p>Non devi confrontare centinaia di offerte o capire tutto da solo: ricevi una selezione ragionata e un punto di riferimento concreto.</p></div><div class="grid-3"><article class="card executive-card-feature"><div class="icon">🧭</div><h3>Consulenza su misura</h3><p>Ogni proposta parte da budget, periodo, interessi e stile di viaggio.</p></article><article class="card executive-card-feature"><div class="icon">🤝</div><h3>Un referente personale</h3><p>Hai una persona reale con cui confrontarti prima, durante e dopo la partenza.</p></article><article class="card executive-card-feature"><div class="icon">✨</div><h3>Esperienza più semplice</h3><p>Meno confusione, più chiarezza e un percorso organizzato passo dopo passo.</p></article></div></div></section>
<section class="section"><div class="container"><div class="section-head"><p class="kicker">Destinazioni in evidenza</p><h2>Inizia dal luogo che ti emoziona di più.</h2></div><div class="dest-grid executive-destinations"><a class="dest jp" href={`${base}destinazioni/#giappone`}><div><small>Destinazione principale</small><h2>Giappone</h2><p>Tokyo, Kyoto, natura, hanami, foliage e cultura autentica.</p></div></a><a class="dest lt" href={`${base}destinazioni/#lituania`}><div><small>Europa da scoprire</small><h2>Lituania</h2><p>Vilnius, Trakai, Kaunas e itinerari nei Paesi Baltici.</p></div></a><a class="dest world" href={`${base}destinazioni/`}><div><small>Altre esperienze</small><h2>Il mondo</h2><p>Mare, tour, crociere, viaggi di nozze e city break.</p></div></a></div></div></section>
<section class="section alt"><div class="container"><div class="section-head"><p class="kicker">Come funziona</p><h2>Tre passaggi semplici, dalla prima idea alla partenza.</h2></div><div class="steps executive-steps"><article class="step"><h3>Raccontami il viaggio</h3><p>Destinazione, periodo, budget e desideri.</p></article><article class="step"><h3>Ricevi una proposta</h3><p>Seleziono le opzioni più coerenti e te le presento in modo chiaro.</p></article><article class="step"><h3>Definiamo i dettagli</h3><p>Rivediamo insieme servizi, tappe e condizioni.</p></article><article class="step"><h3>Parti con assistenza</h3><p>Resto il tuo punto di riferimento.</p></article></div></div></section>
<section class="section"><div class="container testimonial-layout"><div><p class="kicker">Fiducia e trasparenza</p><h2>Un rapporto diretto, senza complicazioni.</h2><p>Il valore del servizio non è solo trovare un viaggio, ma aiutarti a scegliere meglio e partire con maggiore serenità.</p></div><div class="testimonial-card"><span class="quote-mark">“</span><blockquote>Ogni viaggio dovrebbe iniziare con entusiasmo, non con ore di ricerche e dubbi.</blockquote><strong>Davide Fois</strong><p>Travel Consultant • Powered by Nuovevacanze</p></div></div></section>
<section class="section alt"><div class="container"><div class="section-head"><p class="kicker">Domande frequenti</p><h2>Le risposte prima di iniziare.</h2></div><div class="faq-grid">{faq.map(item => (<details class="faq-item"><summary>{item.question}</summary><p>{item.answer}</p></details>))}</div></div></section>
<section class="section"><div class="container cta executive-cta"><div><p class="kicker">Il prossimo viaggio parte da qui</p><h2>Raccontami la tua idea.</h2><p>La richiesta è gratuita e non comporta alcun obbligo di prenotazione.</p></div><div class="actions"><a class="button button-primary" href={`${base}preventivo/`}>Richiedi il preventivo</a><a class="button button-ghost" href="https://wa.me/393389028812?text=Buongiorno%20Davide,%20vorrei%20informazioni%20per%20un%20viaggio." target="_blank" rel="noopener noreferrer">Contattami su WhatsApp</a></div></div></section>
</BaseLayout>
